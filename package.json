{
  "name": "habitat",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 3333",
    "prebuild": "npm run content-check",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "content-check": "node scripts/content-check.mjs",
    "perf-budget": "node scripts/perf-budget.mjs",
    "headers-check": "node scripts/headers-check.mjs",
    "qa:ui": "npx -y playwright test --config=playwright.config.ts",
    "qa:wcag": "node scripts/qa/wcag-audit.mjs",
    "qa:cwv": "node scripts/qa/cwv-audit.mjs",
    "resources-governance": "node scripts/resources-governance.mjs",
    "check": "npm run lint && npm run typecheck && npm run content-check && npm run build && npm run perf-budget"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "^1.5.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rss": "^1.2.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/rss": "^0.0.32",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "typescript": "^5"
  }
}
